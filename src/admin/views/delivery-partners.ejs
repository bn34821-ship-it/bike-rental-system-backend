<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">🧑‍🤝‍🧑</span><span class="stat-label">Total Partners</span></div>
    <strong class="stat-value"><%= stats.total %></strong>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">🟢</span><span class="stat-label">Active (Online)</span></div>
    <strong class="stat-value"><%= stats.active %></strong>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">🟡</span><span class="stat-label">Busy (On Delivery)</span></div>
    <strong class="stat-value"><%= stats.busy %></strong>
  </div>
  <div class="stat-card">
    <div class="stat-head"><span class="stat-icon">🔴</span><span class="stat-label">Offline</span></div>
    <strong class="stat-value"><%= stats.offline %></strong>
  </div>
</div>

<div class="chart-card">
  <h3>Fleet Delivery Management</h3>
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Phone</th>
          <th>Status</th>
          <th>Current Order ID</th>
          <th>Earnings Today</th>
          <th>Rating</th>
          <th>Performance</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!partners.length) { %>
        <tr><td colspan="8" class="empty">No delivery partners found</td></tr>
        <% } %>
        <% partners.forEach((partner) => { %>
        <tr>
          <td><%= partner.name %></td>
          <td><%= partner.phone %></td>
          <td>
            <span class="badge <%= partner.status === 'online' ? 'success' : partner.status === 'busy' ? 'warning' : 'danger' %>">
              <%= partner.status === 'online' ? "Online" : partner.status === 'busy' ? "Busy" : "Offline" %>
            </span>
          </td>
          <td><%= partner.currentOrderId %></td>
          <td class="revenue-positive">₹<%= Number(partner.earningsToday || 0).toFixed(2) %></td>
          <td>⭐ <%= partner.rating %></td>
          <td>
            <small>
              D:<%= partner.totalDeliveries %> |
              SR:<%= partner.successRate %>% |
              Avg:<%= partner.avgDeliveryTime %>m
            </small>
          </td>
          <td class="actions">
            <a class="btn btn-ghost" href="/admin/delivery-partners/<%= partner.id %>">View</a>
            <form class="ajax-form inline-form" data-url="/admin/delivery/<%= partner.id %>/assign">
              <select name="orderId" required>
                <option value="">Assign Order</option>
                <% pendingOrders.forEach((order) => { %>
                <option value="<%= order.id %>"><%= order.id %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn btn-gold">Assign</button>
            </form>
            <form class="ajax-form inline-form" data-url="/admin/delivery/<%= partner.id %>/toggle-online">
              <input type="hidden" name="isOnline" value="<%= partner.status !== 'online' %>" />
              <button type="submit" class="btn btn-ghost"><%= partner.status === 'online' ? 'Go Offline' : 'Go Online' %></button>
            </form>
            <button class="btn btn-danger admin-action" data-url="/admin/delivery/<%= partner.id %>/disable" data-method="POST">Disable</button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
