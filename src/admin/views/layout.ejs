<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin - <%= title %></title>
    <link rel="stylesheet" href="/admin/static/css/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="sidebar">
        <div class="brand">
          <span class="brand-mark">◆</span>
          <span>Bike Admin Pro</span>
        </div>
        <nav class="nav">
          <a class="nav-link <%= active === 'dashboard' ? 'active' : '' %>" href="/admin">
            <span class="nav-icon">📊</span><span>Dashboard</span>
          </a>
          <a class="nav-link <%= active === 'users' ? 'active' : '' %>" href="/admin/users">
            <span class="nav-icon">👥</span><span>Users</span>
          </a>
          <a class="nav-link <%= active === 'bikes' ? 'active' : '' %>" href="/admin/bikes">
            <span class="nav-icon">🚲</span><span>Bikes</span>
          </a>
          <a class="nav-link <%= active === 'orders' ? 'active' : '' %>" href="/admin/orders">
            <span class="nav-icon">📦</span><span>Orders</span>
          </a>
          <a class="nav-link <%= active === 'delivery-partners' ? 'active' : '' %>" href="/admin/delivery-partners">
            <span class="nav-icon">🛵</span><span>Delivery</span>
          </a>
          <a class="nav-link <%= active === 'skipped-days' ? 'active' : '' %>" href="/admin/skipped-days">
            <span class="nav-icon">📅</span><span>Skipped Days</span>
          </a>
          <a class="nav-link <%= active === 'earnings' ? 'active' : '' %>" href="/admin/earnings">
            <span class="nav-icon">💸</span><span>Earnings</span>
          </a>
          <a class="nav-link <%= active === 'analytics' ? 'active' : '' %>" href="/admin/analytics">
            <span class="nav-icon">📈</span><span>Analytics</span>
          </a>
          <a class="nav-link <%= active === 'maintenance' ? 'active' : '' %>" href="/admin/maintenance">
            <span class="nav-icon">🧰</span><span>Maintenance</span>
          </a>
          <a class="nav-link <%= active === 'notifications' ? 'active' : '' %>" href="/admin/notifications">
            <span class="nav-icon">🔔</span><span>Notifications</span>
          </a>
          <a class="nav-link <%= active === 'settings' ? 'active' : '' %>" href="/admin/settings">
            <span class="nav-icon">⚙️</span><span>Settings</span>
          </a>
        </nav>
      </aside>
      <main class="content main-content">
        <header class="topbar">
          <div class="topbar-title-group">
            <h1><%= title %></h1>
            <p>Startup SaaS Admin Dashboard</p>
          </div>
          <div class="topbar-profile">
            <span class="admin-name">Admin</span>
            <span class="profile-circle">A</span>
          </div>
        </header>
        <section class="panel">
          <%- include(bodyView) %>
        </section>
      </main>
    </div>
    <div id="toast-container" class="toast-container"></div>
    <script src="/admin/static/js/admin.js"></script>
  </body>
</html>
